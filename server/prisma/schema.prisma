generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(uuid())
  login      String      @unique
  password   String
  characters Character[]
}

model Character {
  id         String   @id @default(uuid())
  name       String   @unique
  level      Int      @default(1)
  hp         Int      @default(100)
  maxHp      Int      @default(100)
  /** Як у text-rpg DEFAULT_PLAYER_CITY_ID — старт у Gludio */
  cityId     String   @default("l2dop_gludio")
  /** Раса / гілка 1 профи (як у L2): fighter | mystic */
  race       String   @default("Human")
  classBranch String  @default("fighter")
  /** male | female — для портрета героя на екрані Перс */
  gender     String   @default("male")
  /** human_fighter → гілки 1–3 профи (rogue→hawkeye|th→sagittarius|adventurer; scout→hawkeye тощо) */
  l2Profession String  @default("human_fighter")
  adena      BigInt   @default(0)
  /** Накопичений досвід (як у l2dop / lineage npc.exp за кілл) */
  exp        BigInt   @default(0)
  /** Накопичені очки вмінь (npc.sp) */
  sp         Int      @default(0)
  /** Убито мобів (PvE) — лічильник з бою. */
  mobsKilled Int      @default(0)
  /** PvP-карма (PK). Змивається мобами (−15 за kill). */
  karma      Int      @default(0)
  /** Перемоги над іншими гравцями (PvP). */
  pvpWins    Int      @default(0)
  /** Участь у перемозі над рейд-босом (≥1 урон по босу). */
  raidBossKills Int   @default(0)
  /** До якого часу (epoch ms) нік агресора фіолетовий після удару в PvP. */
  pvpAggressorUntilMs BigInt @default(0)
  /** Очікувана поразка в PvP (жертва ще не натиснула «В місто»). */
  pvpPendingDefeatJson Json?
  /** Очікувана PvE-поразка (моб/РБ убив — треба «В місто»). */
  pvePendingDefeatJson Json?
  /** Текст статусу профілю — видимий іншим гравцям на player.html. */
  profileStatus String?
  /** Інвентар + екіп: stacks [{ itemId, qty, enchant? }], eq слот: itemId або { itemId, enchant? } — як l2dop eqbonus */
  inventoryJson Json?
  /** Склад у місті: stacks [{ itemId, qty, enchant? }], maxSlots? */
  warehouseJson Json?
  /** l2dop map.php: світові координати та рух до цілі */
  worldX      Int      @default(83400)
  worldY      Int      @default(147943)
  targetX     Int      @default(0)
  targetY     Int      @default(0)
  moveStartAt DateTime?
  moveFromX   Int      @default(83400)
  moveFromY   Int      @default(147943)
  /** Активний бій на карті: spawnId, mobHp, log — джерело правди на сервері */
  battleJson  Json?
  /** Вивчені бойові скіли (id як у BattleActionId), напр. ["power_strike","war_cry"] */
  skillsLearnedJson Json?
  /**
   * Активні бафи: `[{ skillId, level, expiresAt? }]` як у l2dop (users_buffs / cs1.php + rawdata).
   * `expiresAt` — мс epoch (див. `l2dopBuffDurations.ts`); без поля — постійний до cancel/смерті.
   */
  activeBuffsJson Json?
  /**
   * Перезарядки скілів: `[{ skillId, readyAt }]` (мс epoch). Джерело правди для cooldown
   * поза боєм, переживає F5/вихід з бою (Revival 3h, Battle Roar 10m тощо).
   */
  skillCooldownsJson Json?
  /**
   * Поза боєм: копія battleMods + playerMp після виходу з бою; тики MP/часу — `worldCombatState.ts`.
   * У бою джерело правди лише `battleJson`.
   */
  worldCombatStateJson Json?
  /**
   * Залишок HP мобів на карті по spawnId (між боями для цього персонажа).
   * Після втечі/поразки — той самий моб стартує зі збереженим HP; після kill — запис зникає.
   */
  mobSpawnHpJson Json?
  /**
   * Розкладка панелі скілів у бою: масив із 41 слота `{k,a}|{k,i,id,e}|{k,u,id}|null`.
   * Джерело правди на сервері — переживає очищення кешу / інший пристрій.
   */
  battleHotbarJson Json?
  /** Прогрес квестів (1-ша профа тощо): `{ v: 1, active: { questId, targetProfession, kills } }`. */
  questProgressJson Json?
  /** Позиція в Seven Signs подземеллі (карта катакомб/некрополю). */
  dungeonStateJson Json?
  /** Щоденні завдання: `{ v: 1, resetDayKey, playtimeSec, tasks }`. */
  dailyQuestsJson Json?
  /** cs1.php $heroic: 1 — «атака», 2 — «захист», 3 — «підмога» (геройські скіли 395…). */
  buffHeroicTier    Int?
  /** cs1.php $zealot для скіла 420 (Zealot). */
  buffZealotStacks  Int?
  /** Останній перегляд чату — для лічильника непрочитаних відповідей. */
  chatRepliesReadAt DateTime @default(now())
  revision   Int      @default(1)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUpdate DateTime @updatedAt
  chatMessages ChatMessage[]
  marketListings MarketListing[]
  /** Клан гравця; null — без клану. */
  clanId     String?
  /** leader | member */
  clanRole   String?
  clan       Clan?    @relation("ClanMember", fields: [clanId], references: [id], onDelete: SetNull)
  ledClan    Clan?    @relation("ClanLeader")
  clanInvitesSent ClanInvite[] @relation("ClanInviteInviter")
  clanInvitesRecv ClanInvite[] @relation("ClanInviteTarget")
  clanChatMessages ClanChatMessage[]
  /** Паті: лідерство без partyId на Character — membership лише через PartyMember. */
  ledParty         Party?        @relation("PartyLeader")
  partyMembership  PartyMember?
  partyInvitesSent PartyInvite[] @relation("PartyInviteInviter")
  partyInvitesRecv PartyInvite[] @relation("PartyInviteTarget")
  partyBattleParticipants PartyBattleParticipant[]
  clanSiegeParticipations ClanSiegeParticipant[]
  clanSiegeWallActions    ClanSiegeWallAction[]

  @@index([userId, lastUpdate(sort: Desc)])
  @@index([clanId])
}

/** Група до 5 гравців (лідер + 4). Соціальний стан — partyVersion, не Character.revision. */
model Party {
  id                String        @id @default(uuid())
  leaderCharacterId String        @unique
  leader            Character     @relation("PartyLeader", fields: [leaderCharacterId], references: [id], onDelete: Cascade)
  version           Int           @default(1)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  members           PartyMember[]
  invites           PartyInvite[]
  battleSessions    PartyBattleSession[]
}

enum PartyBattleSessionState {
  active
  victory
  ended
}

enum PartyBattlePlayfield {
  world
  dungeon
}

/** Спільний PvE-бій паті: одне mobHp на групу (фаза 2). Історія зберігається після disband Party. */
model PartyBattleSession {
  id                     String                   @id @default(uuid())
  partyId                String?
  originPartyId          String
  activePartyKey         String?                  @unique
  playfield              PartyBattlePlayfield     @default(world)
  dungeonId              String?
  spawnId                String
  canonicalMobTemplateId String
  mobWorldX              Int?
  mobWorldY              Int?
  mobMapX                Int?
  mobMapY                Int?
  mobHp                  Int
  mobMaxHp               Int
  battleVersion          Int                      @default(1)
  state                  PartyBattleSessionState  @default(active)
  lastActivityAt         DateTime                 @default(now())
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  endedAt                DateTime?
  endReason              String?
  party                  Party?                   @relation(fields: [partyId], references: [id], onDelete: SetNull)
  participants           PartyBattleParticipant[]
  rewards                PartyKillReward[]

  @@index([originPartyId])
  @@index([spawnId, state])
  @@index([lastActivityAt, state])
}

model PartyBattleParticipant {
  partyBattleId       String
  characterId         String
  joinedAt            DateTime  @default(now())
  lastActivityAt      DateTime  @default(now())
  lastDamagingHitAtMs BigInt?
  totalDamage         Int       @default(0)
  active              Boolean   @default(true)
  leftAt              DateTime?
  partyBattle         PartyBattleSession @relation(fields: [partyBattleId], references: [id], onDelete: Cascade)
  character           Character          @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([partyBattleId, characterId])
  @@index([characterId])
}

/** Idempotency: одна session — одна нагорода на characterId. */
model PartyKillReward {
  partyBattleId String
  characterId   String
  expGain       Int
  spGain        Int
  adenaGain     BigInt
  createdAt     DateTime @default(now())
  /** Stage D: UI acknowledgement для non-killer reward notice. */
  notifiedAt    DateTime?
  partyBattle   PartyBattleSession @relation(fields: [partyBattleId], references: [id], onDelete: Cascade)

  @@id([partyBattleId, characterId])
}

model PartyMember {
  partyId     String
  characterId String    @unique
  slotOrder   Int
  joinedAt    DateTime  @default(now())
  party       Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@id([partyId, characterId])
  @@unique([partyId, slotOrder])
  @@index([partyId])
}

/** Активні запрошення; після accept/decline/expiry запис видаляється. */
model PartyInvite {
  id                 String    @id @default(uuid())
  partyId            String
  party              Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)
  inviterCharacterId String
  inviter            Character @relation("PartyInviteInviter", fields: [inviterCharacterId], references: [id], onDelete: Cascade)
  targetCharacterId  String
  target             Character @relation("PartyInviteTarget", fields: [targetCharacterId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  expiresAt          DateTime

  @@unique([partyId, targetCharacterId])
  @@index([targetCharacterId])
}

model Clan {
  id           String      @id @default(uuid())
  name         String      @unique
  leaderId     String      @unique
  leader       Character   @relation("ClanLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  members      Character[] @relation("ClanMember")
  /** Текст оголошення клану (редагує лідер). */
  announcement   String      @default("")
  /** Куплене благословення Клан-холу; null — ще не куплено. */
  hallBlessingAt DateTime?
  /** Рівень клану (1–8). */
  level          Int         @default(1)
  /** Очки клану (нагороди облог, майбутнє підвищення рівня). Не рейтинг. */
  clanPoints     Int         @default(0)
  /** Емблема клану (1–40); null — ще не обрана. */
  emblemId       Int?
  createdAt      DateTime    @default(now())
  invites        ClanInvite[]
  chatMessages   ClanChatMessage[]
  ownedCastles   CityCastle[] @relation("CityCastleOwner")
  siegeClanDamages ClanSiegeClanDamage[]
  siegeWins        ClanSiege[] @relation("ClanSiegeWinner")
  siegeRewards     ClanSiegeRewardLedger[]
}

model ClanInvite {
  id                 String    @id @default(uuid())
  clanId             String
  clan               Clan      @relation(fields: [clanId], references: [id], onDelete: Cascade)
  inviterCharacterId String
  inviter            Character @relation("ClanInviteInviter", fields: [inviterCharacterId], references: [id], onDelete: Cascade)
  targetCharacterId  String
  target             Character @relation("ClanInviteTarget", fields: [targetCharacterId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  /** Коли запрошення показано під HUD (перша ігрова дія). */
  deliveredAt        DateTime?
  respondedAt        DateTime?
  /** accepted | declined */
  response           String?

  @@index([targetCharacterId, deliveredAt])
  @@index([targetCharacterId, respondedAt])
  @@index([clanId, targetCharacterId])
}

model ClanChatMessage {
  id          String    @id @default(uuid())
  clanId      String
  clan        Clan      @relation(fields: [clanId], references: [id], onDelete: Cascade)
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  text        String
  createdAt   DateTime  @default(now())

  @@index([clanId, createdAt(sort: Desc)])
}

/** Власник замку / міста облоги (Stage A — 8 міст). */
model CityCastle {
  cityId      String    @id
  ownerClanId String?
  ownerClan   Clan?     @relation("CityCastleOwner", fields: [ownerClanId], references: [id], onDelete: SetNull)
  capturedAt  DateTime?
  updatedAt   DateTime  @updatedAt
}

/** Конкретна облога міста (розклад + стіна). */
model ClanSiege {
  id              String    @id @default(uuid())
  cityId          String
  /** null = суботній розклад; "__clan_siege_test__" = CLAN_SIEGE_TEST_ENABLED override. */
  testKey         String?
  startsAt        DateTime
  endsAt          DateTime
  /** scheduled | active | finished */
  state           String
  wallHp          Int
  wallMaxHp       Int
  version         Int       @default(0)
  winnerClanId    String?
  winnerClan      Clan?     @relation("ClanSiegeWinner", fields: [winnerClanId], references: [id], onDelete: SetNull)
  finishedAt      DateTime?
  /** wall_destroyed | time_expired */
  finishReason    String?
  rewardGrantedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  clanDamages     ClanSiegeClanDamage[]
  participants    ClanSiegeParticipant[]
  wallActions     ClanSiegeWallAction[]
  rewardLedger    ClanSiegeRewardLedger?

  @@unique([cityId, startsAt])
  @@unique([cityId, testKey])
  @@index([state, startsAt])
  @@index([state, endsAt])
  @@index([cityId, state])
}

/** Сумарний урон клану по стіні за одну облогу. */
model ClanSiegeClanDamage {
  id          String    @id @default(uuid())
  siegeId     String
  siege       ClanSiege @relation(fields: [siegeId], references: [id], onDelete: Cascade)
  clanId      String
  clan        Clan      @relation(fields: [clanId], references: [id], onDelete: Cascade)
  totalDamage Int       @default(0)
  firstHitAt  DateTime?
  lastHitAt   DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([siegeId, clanId])
  @@index([siegeId])
  @@index([siegeId, totalDamage(sort: Desc)])
  @@index([clanId])
}

/** Участь персонажа в облозі (cooldown, персональний урон). */
model ClanSiegeParticipant {
  id               String    @id @default(uuid())
  siegeId          String
  siege            ClanSiege @relation(fields: [siegeId], references: [id], onDelete: Cascade)
  characterId      String
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  clanId           String
  totalWallDamage  Int       @default(0)
  lastWallAttackAt           DateTime?
  lastSeenAt                 DateTime?
  joinedAt                   DateTime  @default(now())
  eliminatedAt               DateTime?
  eliminatedByCharacterId    String?
  lastIncomingAttackerCharacterId String?
  lastIncomingAttackerName        String?
  lastIncomingDamage              Int?
  lastIncomingAt                  DateTime?

  @@unique([siegeId, characterId])
  @@index([siegeId])
  @@index([characterId])
}

/** Ledger ударів по стіні — idempotency (siegeId + characterId + actionId). */
model ClanSiegeWallAction {
  id                   String    @id @default(uuid())
  siegeId              String
  siege                ClanSiege @relation(fields: [siegeId], references: [id], onDelete: Cascade)
  characterId          String
  character            Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  actionId             String
  damage               Int
  wallHpAfter          Int
  siegeVersionAfter    Int
  characterTotalAfter  Int
  clanTotalAfter       Int
  createdAt            DateTime  @default(now())

  @@unique([siegeId, characterId, actionId])
  @@index([siegeId])
}

/** Ідемпотентний ledger нагороди за облогу (один запис на siegeId). */
model ClanSiegeRewardLedger {
  id        String    @id @default(uuid())
  siegeId   String    @unique
  siege     ClanSiege @relation(fields: [siegeId], references: [id], onDelete: Cascade)
  clanId    String
  clan      Clan      @relation(fields: [clanId], references: [id], onDelete: Cascade)
  points    Int
  grantedAt DateTime  @default(now())
}

model MarketListing {
  id                String    @id @default(uuid())
  sellerCharacterId String
  sellerCharacter   Character @relation(fields: [sellerCharacterId], references: [id], onDelete: Cascade)
  sellerName        String
  itemId            Int
  qty               Int
  enchant           Int       @default(0)
  priceAdena        BigInt    @default(0)
  priceCoinOfLuck   Int       @default(0)
  createdAt         DateTime  @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([sellerCharacterId])
}

model ChatMessage {
  id          String    @id @default(uuid())
  /** all | trade | my */
  channel     String    @default("all")
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  text        String
  replyToCharacterId   String?
  replyToCharacterName String?
  createdAt   DateTime  @default(now())

  @@index([channel, createdAt(sort: Desc)])
  @@index([replyToCharacterId, createdAt(sort: Desc)])
}

/** Спільний стан world РБ/епіка: HP, aggro-ціль, учасники. */
model WorldBossSession {
  spawnId   String   @id
  stateJson Json
  updatedAt DateTime @updatedAt
}

/** Глобальні новини сервера (Новости в чаті). */
model ServerNewsEntry {
  id         String   @id @default(uuid())
  /** mammon_spawn | mammon_blacksmith_spawn | player_join */
  kind       String
  locationEn String?
  playerName String?
  createdAt  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

/** Ключ–значення для дедуплікації подій (напр. rотація Маммона). */
model ServerMeta {
  key   String @id
  value String
}
