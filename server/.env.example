# Синхронно з docker-compose.yml (БД l2reborn, user/pass postgres).
# Копіюй у server/.env і підлаштуй, якщо Postgres інший.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/l2reborn?schema=public"

# Локально — будь-який рядок. На production — унікальний ≥32 символів (openssl rand -base64 48).
JWT_SECRET="replace-with-long-random-string-min-32-chars"

PORT=3000

# Лише для локальної розробки: /dev-boost.html і POST /character/dev-self-boost.
# На production не вмикати — сервер не стартує з L2DOP_DEV_SELF_BOOST=1.
#L2DOP_DEV_SELF_BOOST=1

# Якщо EADDRINUSE (порт зайнятий) — зміни на 3001 або зупини інший процес на цьому порту.
